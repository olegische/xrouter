{
  "name": "xrouter-browser-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run wasm:build && vite",
    "build": "npm run wasm:build && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json",
    "wasm:build": "wasm-pack build ../xrouter/crates/xrouter-browser --target web --out-dir ../../../browser-demo/src/lib/wasm --dev"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.28.2",
    "svelte-check": "^4.1.6",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vite": "^6.2.2"
  }
}
